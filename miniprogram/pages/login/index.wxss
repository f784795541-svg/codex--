.screen-auth {
  padding-top: 24rpx;
}

.auth-intro-card {
  position: relative;
  overflow: hidden;
  padding: 24rpx 24rpx 26rpx;
  border-radius: 34rpx;
  background:
    radial-gradient(circle at top right, rgba(198, 224, 245, 0.44), transparent 34%),
    radial-gradient(circle at left top, rgba(208, 232, 225, 0.58), transparent 30%),
    linear-gradient(180deg, rgba(250, 253, 255, 0.98), rgba(243, 248, 251, 0.98));
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.96),
    0 24rpx 48rpx rgba(78, 102, 126, 0.1);
}

.auth-brand-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.auth-brand-pill {
  min-height: 32rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.84);
  color: #17343b;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.auth-brand-pill-soft {
  background: rgba(225, 240, 232, 0.92);
  color: #396d67;
}

.auth-highlight-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.auth-highlight-card {
  padding: 16rpx 16rpx 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.68);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.92);
}

.auth-highlight-title {
  display: block;
  color: #17343b;
  font-size: 24rpx;
  font-weight: 700;
}

.auth-highlight-copy {
  display: block;
  margin-top: 6rpx;
  color: #688185;
  font-size: 22rpx;
  line-height: 1.56;
}

.auth-form-card {
  margin-top: 18rpx;
  padding-top: 24rpx;
}

.auth-form-head {
  margin-bottom: 4rpx;
}

.auth-form-kicker {
  display: block;
  color: #4e7a72;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
}

.auth-tip {
  margin-top: 16rpx;
  color: #70878b;
  font-size: 23rpx;
  line-height: 1.58;
}

.auth-primary-button {
  margin-top: 16rpx;
}

.auth-secondary-button {
  margin-top: 12rpx;
}
