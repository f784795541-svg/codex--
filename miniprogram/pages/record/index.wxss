.screen-record .hero-panel {
  margin-top: 4rpx;
  padding-bottom: 24rpx;
}

.record-tabs-shell {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 20rpx;
  padding: 10rpx;
  border-radius: 24rpx;
  background: rgba(247, 251, 251, 0.92);
  box-shadow: 0 14rpx 34rpx rgba(70, 104, 110, 0.06);
}

.status-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 18rpx;
  padding: 20rpx 22rpx;
  border-radius: 26rpx;
  background: linear-gradient(135deg, rgba(232, 242, 243, 0.98) 0%, rgba(218, 233, 235, 0.94) 100%);
  box-shadow: 0 14rpx 34rpx rgba(70, 104, 110, 0.08);
}

.status-banner-title {
  color: #1d4047;
  font-size: 27rpx;
  font-weight: 700;
}

.status-banner-copy {
  margin-top: 8rpx;
  color: #698287;
  font-size: 22rpx;
  line-height: 1.5;
}

.status-banner-action {
  flex-shrink: 0;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
  color: #3d656b;
  font-size: 22rpx;
}

.step-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.food-default-note {
  margin-top: 16rpx;
  color: #34575f;
  font-size: 23rpx;
  line-height: 1.6;
  font-weight: 700;
}

.step-chip {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #e8f0f1;
  color: #4a676d;
  font-size: 21rpx;
  line-height: 1.4;
}

.food-selected {
  margin-top: 22rpx;
  padding: 22rpx 20rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #eef6f7 0%, #e7f0f1 100%);
}

.food-selected-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
}

.food-selected-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1c4047;
}

.food-selected-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #749095;
}

.food-selected-badge {
  flex-shrink: 0;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.88);
  color: #40666d;
  font-size: 21rpx;
}

.food-preview-chip {
  margin-top: 16rpx;
  display: inline-flex;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
  color: #456a70;
  font-size: 22rpx;
}

.food-results {
  margin-top: 18rpx;
}

.food-result-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(229, 237, 238, 0.92);
}

.food-result-item:last-child {
  border-bottom: 0;
  padding-bottom: 0;
}

.food-result-item-active .item-title {
  color: #244d55;
}

.food-result-item-active .item-meta {
  color: #557a81;
}

.soft-tip {
  margin-top: 16rpx;
  padding: 16rpx 18rpx;
  border-radius: 22rpx;
  background: rgba(238, 246, 247, 0.92);
  color: #6b8489;
  font-size: 22rpx;
  line-height: 1.62;
}

.support-copy {
  margin-top: 14rpx;
  color: #738d92;
  font-size: 22rpx;
  line-height: 1.58;
}

.food-empty {
  margin-top: 18rpx;
}

.insight-panel {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: rgba(241, 247, 248, 0.95);
  border: 1rpx solid rgba(220, 232, 233, 0.9);
}

.insight-panel-compact {
  margin-top: 16rpx;
}

.insight-label {
  color: #739095;
  font-size: 21rpx;
}

.insight-value {
  margin-top: 10rpx;
  color: #1d4047;
  font-size: 26rpx;
  line-height: 1.45;
  font-weight: 700;
}

.hero-pill-wide {
  flex: 1;
  min-width: 0;
}

.hero-pill-value-note {
  font-size: 24rpx;
  line-height: 1.45;
}
