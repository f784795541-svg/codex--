.hero-panel-home {
  margin-top: 4rpx;
}

.screen-home .hero-subtitle {
  max-width: 620rpx;
}

.hero-summary-card {
  position: relative;
  z-index: 1;
  margin-top: 16rpx;
  padding: 16rpx 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #4f6a6f;
  font-size: 22rpx;
  line-height: 1.58;
}

.metric-grid-dense .metric-card {
  min-height: 150rpx;
}

.support-inline-copy {
  margin-top: 12rpx;
  color: #738d92;
  font-size: 21rpx;
  line-height: 1.56;
}

.macro-row {
  margin-top: 18rpx;
}

.macro-row-last {
  padding-bottom: 4rpx;
}

.macro-row-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.macro-row-value {
  font-size: 23rpx;
  font-weight: 600;
  color: #244950;
}

.macro-row-meta {
  margin-top: 6rpx;
  font-size: 21rpx;
  color: #759095;
}

.progress-track {
  overflow: hidden;
  margin-top: 12rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: #e1ecee;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
}

.progress-fill-protein {
  background: linear-gradient(90deg, #4b7982 0%, #7caab0 100%);
}

.progress-fill-fat {
  background: linear-gradient(90deg, #5a8b86 0%, #91b7a2 100%);
}

.progress-fill-carb {
  background: linear-gradient(90deg, #547389 0%, #88a9bb 100%);
}

.progress-fill-default {
  background: linear-gradient(90deg, #5e8288 0%, #87a8ad 100%);
}

.suggestion-list {
  margin-top: 14rpx;
}

.suggestion-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid rgba(229, 237, 238, 0.92);
}

.suggestion-item:last-child {
  border-bottom: 0;
  padding-bottom: 0;
}

.suggestion-dot {
  width: 14rpx;
  height: 14rpx;
  margin-top: 10rpx;
  border-radius: 50%;
  background: #5a858c;
  flex-shrink: 0;
}

.suggestion-copy {
  flex: 1;
  color: #5f7b80;
  font-size: 23rpx;
  line-height: 1.62;
}

.warning-strip {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.warning-chip {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(214, 227, 229, 0.94);
  color: #49686d;
  font-size: 21rpx;
  line-height: 1.4;
}

.action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.action-button {
  flex: 1;
  margin-top: 0;
}

.weight-list {
  margin-top: 16rpx;
}

.weight-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(229, 237, 238, 0.92);
}

.weight-row:last-child {
  border-bottom: 0;
  padding-bottom: 0;
}

.weight-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #1c4047;
}

.weight-date {
  margin-top: 6rpx;
  font-size: 21rpx;
  color: #799297;
}

.weight-chip {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #e5eff0;
  color: #40656b;
  font-size: 22rpx;
}

.meal-grid {
  margin-top: 18rpx;
  display: grid;
  gap: 16rpx;
}

.meal-card {
  padding: 20rpx;
  border-radius: 26rpx;
  background: linear-gradient(180deg, rgba(246, 250, 250, 0.98) 0%, rgba(238, 245, 245, 0.98) 100%);
  border: 1rpx solid rgba(215, 228, 229, 0.98);
}

.meal-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.meal-card-badge {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(219, 232, 233, 0.95);
  color: #3f676d;
  font-size: 21rpx;
  font-weight: 600;
  line-height: 1.3;
}

.meal-card-kcal {
  color: #30545b;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.3;
}

.meal-card-focus {
  margin-top: 14rpx;
  color: #21464d;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.45;
}

.meal-card-structure {
  margin-top: 8rpx;
  color: #5f7b80;
  font-size: 22rpx;
  line-height: 1.56;
}

.meal-card-summary {
  margin-top: 12rpx;
  color: #32575e;
  font-size: 23rpx;
  line-height: 1.6;
}

.meal-item-list {
  margin-top: 14rpx;
  display: grid;
  gap: 10rpx;
}

.meal-item-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  padding: 12rpx 14rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.72);
}

.meal-item-name {
  flex: 1;
  color: #244950;
  font-size: 23rpx;
  line-height: 1.45;
}

.meal-item-meta {
  color: #6c888d;
  font-size: 21rpx;
  line-height: 1.4;
}

.meal-card-status {
  margin-top: 14rpx;
  color: #6f8b90;
  font-size: 21rpx;
  line-height: 1.5;
}
