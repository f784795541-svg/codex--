.screen-trend .hero-panel {
  margin-top: 4rpx;
}

.trend-compact-grid .metric-card {
  min-height: 140rpx;
}

.screen-trend .support-inline-copy {
  margin-top: 12rpx;
  color: #738d92;
  font-size: 21rpx;
  line-height: 1.56;
}

.macro-row {
  margin-top: 18rpx;
}

.macro-row-last {
  padding-bottom: 4rpx;
}

.macro-row-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.macro-row-value {
  font-size: 23rpx;
  font-weight: 600;
  color: #244950;
}

.macro-row-meta {
  margin-top: 6rpx;
  font-size: 21rpx;
  color: #759095;
}

.progress-track {
  overflow: hidden;
  margin-top: 12rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: #e1ecee;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
}

.progress-fill-protein {
  background: linear-gradient(90deg, #4b7982 0%, #7caab0 100%);
}

.progress-fill-fat {
  background: linear-gradient(90deg, #5a8b86 0%, #91b7a2 100%);
}

.progress-fill-carb {
  background: linear-gradient(90deg, #547389 0%, #88a9bb 100%);
}

.trend-summary-panel {
  margin-top: 16rpx;
  padding: 18rpx 18rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #eef6f7 0%, #e7f0f1 100%);
}

.suggestion-list {
  margin-top: 14rpx;
}

.suggestion-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid rgba(229, 237, 238, 0.92);
}

.suggestion-item:last-child {
  border-bottom: 0;
  padding-bottom: 0;
}

.suggestion-dot {
  width: 14rpx;
  height: 14rpx;
  margin-top: 10rpx;
  border-radius: 50%;
  background: #5a858c;
  flex-shrink: 0;
}

.suggestion-copy {
  flex: 1;
  color: #5f7b80;
  font-size: 23rpx;
  line-height: 1.62;
}

.warning-strip {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.warning-chip {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(214, 227, 229, 0.94);
  color: #49686d;
  font-size: 21rpx;
  line-height: 1.4;
}

.trend-report-list {
  margin-top: 16rpx;
}

.trend-report-item {
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(229, 237, 238, 0.92);
}

.trend-report-item:last-child {
  border-bottom: 0;
  padding-bottom: 0;
}

.trend-report-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.trend-report-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 12rpx;
}

.trend-report-metric {
  padding: 14rpx 14rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(239, 246, 247, 0.94);
}

.trend-mini-value {
  display: block;
  margin-top: 8rpx;
  color: #193b42;
  font-size: 24rpx;
  line-height: 1.34;
  font-weight: 700;
}

.trend-weight-highlight {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 14rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  background: rgba(239, 246, 247, 0.94);
}

.trend-weight-value {
  margin-top: 6rpx;
  font-size: 32rpx;
  line-height: 1.16;
  font-weight: 700;
  color: #183941;
}

.trend-weight-note {
  color: #6f888d;
  font-size: 21rpx;
  line-height: 1.52;
  text-align: right;
}

.weight-mini-chart {
  margin-top: 16rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  background: rgba(239, 246, 247, 0.94);
}

.weight-mini-chart-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 16rpx;
}

.weight-mini-bars {
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
  margin-top: 18rpx;
}

.weight-mini-bar-item {
  flex: 1;
  min-width: 0;
}

.weight-mini-bar-value {
  font-size: 19rpx;
  line-height: 1.4;
  color: #6a8488;
  text-align: center;
}

.weight-mini-bar-track {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  height: 150rpx;
  margin-top: 10rpx;
  padding: 8rpx 0;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.86);
}

.weight-mini-bar-fill {
  width: 24rpx;
  min-height: 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #7caab0 0%, #2f5b62 100%);
  box-shadow: 0 10rpx 22rpx rgba(61, 104, 112, 0.16);
}

.weight-mini-bar-date {
  margin-top: 10rpx;
  font-size: 20rpx;
  line-height: 1.4;
  color: #7b9498;
  text-align: center;
}

.weight-list {
  margin-top: 16rpx;
}

.weight-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(229, 237, 238, 0.92);
}

.weight-row:last-child {
  border-bottom: 0;
  padding-bottom: 0;
}

.weight-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #1c4047;
}

.weight-date {
  margin-top: 6rpx;
  font-size: 21rpx;
  color: #799297;
}

.weight-chip {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #e5eff0;
  color: #40656b;
  font-size: 22rpx;
}

.bmi-range-shell {
  margin-top: 18rpx;
}

.bmi-range {
  position: relative;
  display: grid;
  grid-template-columns: 1.05fr 1.2fr 1fr 1fr;
  overflow: hidden;
  border-radius: 999rpx;
}

.bmi-segment {
  min-height: 62rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 600;
}

.bmi-under {
  background: #81aeb0;
}

.bmi-normal {
  background: #5f8f86;
}

.bmi-over {
  background: #ca945c;
}

.bmi-obese {
  background: #c06a58;
}

.bmi-marker {
  position: absolute;
  bottom: 100%;
  transform: translateX(-50%);
  margin-bottom: 10rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #1d4047;
  color: #ffffff;
  font-size: 20rpx;
  line-height: 1;
  white-space: nowrap;
}

.bmi-marker::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 100%;
  transform: translateX(-50%);
  width: 12rpx;
  height: 12rpx;
  border-radius: 4rpx;
  background: #1d4047;
}

.bmi-scale {
  display: flex;
  justify-content: space-between;
  margin-top: 12rpx;
  color: #6f888d;
  font-size: 20rpx;
}
