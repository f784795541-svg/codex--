.screen-profile .hero-panel {
  margin-top: 4rpx;
  padding-bottom: 24rpx;
}

.screen-profile .section-caption {
  margin-bottom: 4rpx;
}

.profile-focus-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.profile-focus-chip {
  padding: 9rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.82);
  color: #496a70;
  font-size: 21rpx;
}

.profile-account-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 12rpx;
}

.profile-account-copy {
  flex: 1;
  min-width: 0;
}

.profile-name {
  font-size: 30rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #1b3f46;
}

.profile-logout-btn {
  flex-shrink: 0;
  min-width: 156rpx;
  margin: 0;
  border: 1rpx solid #c9dadd;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.86);
  color: #335d63;
  font-size: 23rpx;
  font-weight: 600;
}

.support-inline-copy {
  margin-top: 12rpx;
  color: #738d92;
  font-size: 21rpx;
  line-height: 1.56;
}

.profile-save-notice {
  margin-top: 12rpx;
  padding: 14rpx 16rpx;
  border-radius: 22rpx;
  background: rgba(238, 246, 247, 0.95);
  color: #476b71;
  font-size: 21rpx;
  line-height: 1.54;
}

.profile-section-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 20rpx;
}

.profile-section-title {
  color: #1c4047;
  font-size: 24rpx;
  font-weight: 700;
}

.profile-section-note {
  color: #7a9296;
  font-size: 21rpx;
  line-height: 1.46;
  text-align: right;
}
