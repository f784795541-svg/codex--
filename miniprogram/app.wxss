page {
  min-height: 100%;
  background: #dfecee;
  color: #163138;
  font-size: 28rpx;
}

view,
text,
button,
input,
picker,
textarea {
  box-sizing: border-box;
}

.screen {
  min-height: 100vh;
  padding: 20rpx 20rpx 44rpx;
  background:
    linear-gradient(180deg, rgba(247, 251, 251, 0.97) 0%, rgba(230, 240, 241, 0.95) 42%, rgba(221, 234, 236, 1) 100%);
}

.hero-panel {
  position: relative;
  overflow: hidden;
  padding: 26rpx 24rpx 28rpx;
  border-radius: 30rpx;
  background: linear-gradient(160deg, rgba(248, 252, 252, 0.98) 0%, rgba(230, 241, 242, 0.92) 100%);
  box-shadow: 0 12rpx 28rpx rgba(67, 102, 108, 0.09);
}

.hero-panel::after {
  content: "";
  position: absolute;
  top: -88rpx;
  right: -72rpx;
  width: 250rpx;
  height: 250rpx;
  border-radius: 50%;
  background: rgba(122, 164, 170, 0.14);
}

.hero-kicker {
  position: relative;
  z-index: 1;
  font-size: 22rpx;
  letter-spacing: 6rpx;
  color: #6f878b;
}

.hero-title {
  position: relative;
  z-index: 1;
  margin-top: 12rpx;
  font-size: 46rpx;
  line-height: 1.14;
  font-weight: 700;
  color: #17343b;
}

.hero-subtitle {
  position: relative;
  z-index: 1;
  margin-top: 12rpx;
  color: #698286;
  line-height: 1.62;
  font-size: 23rpx;
}

.hero-pill-row {
  position: relative;
  z-index: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.hero-pill {
  min-width: 196rpx;
  padding: 14rpx 16rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.78);
  box-shadow: inset 0 0 0 1rpx rgba(223, 235, 236, 0.8);
}

.hero-pill-label {
  display: block;
  font-size: 20rpx;
  color: #70888c;
}

.hero-pill-value {
  display: block;
  margin-top: 6rpx;
  font-size: 26rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #17343b;
}

.card {
  margin-top: 18rpx;
  padding: 22rpx 20rpx;
  border-radius: 26rpx;
  background: rgba(248, 252, 252, 0.92);
  box-shadow: 0 10rpx 22rpx rgba(70, 104, 110, 0.07);
}

.card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.card-kicker {
  display: block;
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: #7a9194;
}

.section-title {
  margin-top: 8rpx;
  font-size: 31rpx;
  line-height: 1.24;
  font-weight: 700;
  color: #1d3d44;
}

.section-caption,
.card-note {
  margin-top: 8rpx;
  color: #71898d;
  font-size: 23rpx;
  line-height: 1.58;
}

.card-badge {
  flex-shrink: 0;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #e4eff0;
  color: #3f656c;
  font-size: 21rpx;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.metric-card {
  min-height: 150rpx;
  padding: 18rpx 16rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #f1f7f7 0%, #e7f0f1 100%);
}

.metric-label {
  font-size: 22rpx;
  color: #70878b;
}

.metric-value {
  margin-top: 10rpx;
  font-size: 34rpx;
  line-height: 1.08;
  font-weight: 700;
  color: #17343b;
}

.metric-note {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #739094;
}

.row,
.field-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.field {
  margin-top: 16rpx;
}

.field-label {
  display: block;
  margin-bottom: 12rpx;
  color: #496267;
  font-size: 23rpx;
}

.input,
.picker,
.textarea {
  width: 100%;
  min-height: 88rpx;
  padding: 0 20rpx;
  border-radius: 22rpx;
  border: 1rpx solid rgba(182, 204, 207, 0.72);
  background: rgba(239, 246, 247, 0.95);
  color: #163138;
}

.input {
  line-height: 88rpx;
}

.picker {
  display: flex;
  align-items: center;
}

.picker-display {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  min-height: 88rpx;
  color: #163138;
  font-size: 28rpx;
  line-height: 1.4;
}

.picker-display-text {
  flex: 1;
  min-width: 0;
}

.picker-display-placeholder {
  color: #8aa0a4;
}

.picker-display-icon {
  flex-shrink: 0;
  margin-left: 16rpx;
  color: #7c9498;
  font-size: 24rpx;
  line-height: 1;
}

.textarea {
  min-height: 192rpx;
  padding-top: 24rpx;
  padding-bottom: 24rpx;
}

.button,
.button-secondary {
  margin-top: 18rpx;
  border-radius: 999rpx;
  font-size: 27rpx;
  font-weight: 600;
  min-height: 84rpx;
  line-height: 84rpx;
}

.button {
  border: 0;
  background: linear-gradient(135deg, #27555d 0%, #6f9ea3 100%);
  color: #ffffff;
}

.button[disabled] {
  opacity: 0.55;
}

.button-secondary {
  border: 1rpx solid #c9dadd;
  background: rgba(255, 255, 255, 0.86);
  color: #335d63;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 18rpx;
}

.tab {
  min-height: 72rpx;
  padding: 16rpx 10rpx;
  border-radius: 999rpx;
  background: rgba(228, 238, 239, 0.94);
  color: #627d81;
  font-size: 23rpx;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-active {
  background: #294f57;
  color: #ffffff;
  box-shadow: 0 8rpx 18rpx rgba(41, 79, 87, 0.15);
}

.list-item {
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(229, 237, 238, 0.9);
}

.list-item:last-child {
  border-bottom: 0;
  padding-bottom: 0;
}

.item-title {
  font-size: 28rpx;
  line-height: 1.36;
  font-weight: 600;
  color: #1f4146;
}

.item-meta {
  margin-top: 8rpx;
  color: #708b8f;
  font-size: 23rpx;
  line-height: 1.66;
}

.pill {
  display: inline-block;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #e3eeef;
  color: #37676c;
  font-size: 22rpx;
}

.empty {
  margin-top: 18rpx;
  padding: 28rpx 24rpx;
  border-radius: 26rpx;
  background: rgba(247, 251, 251, 0.84);
  color: #748e92;
  font-size: 24rpx;
  line-height: 1.6;
  box-shadow: 0 10rpx 22rpx rgba(70, 104, 110, 0.06);
}

.empty-title {
  display: block;
  margin-bottom: 12rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #23484f;
}
